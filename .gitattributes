# Large files stored with Git LFS
node_modules/@next/swc-darwin-arm64/next-swc.darwin-arm64.node filter=lfs diff=lfs merge=lfs -text
*.your_large_file_extension filter=lfs diff=lfs merge=lfs -text

# Force GitHub Linguist to recognize specific languages with adjusted priorities
*.py linguist-language=Python
*.java linguist-language=Java
*.go linguist-language=Go
*.rs linguist-language=Rust

# Exclude other languages or files from language stats
*.js linguist-vendored
*.jsx linguist-vendored
*.ts linguist-vendored
*.tsx linguist-vendored
*.html linguist-vendored
*.css linguist-vendored
*.json linguist-vendored

# Vendor directories
node_modules/* linguist-vendored
dist/* linguist-vendored
coverage/* linguist-vendored

# Temporary and build files (not part of language stats)
build/* linguist-vendored
.cache/* linguist-vendored
venv/* linguist-vendored
new_venv/* linguist-vendored
logs/* linguist-vendored
_site/* linguist-vendored
*.tmp linguist-vendored
*.bak linguist-vendored
*.swp linguist-vendored
*.temp linguist-vendored

# Large media files handled by LFS
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text

# SSL and sensitive files (not part of language stats)
ssl/* linguist-vendored
*.crt linguist-vendored
*.csr linguist-vendored
*.key linguist-vendored
*.db linguist-vendored

# Test and coverage files
test.txt linguist-vendored
test_flask.py linguist-vendored
.nyc_output/* linguist-vendored
*.html.report linguist-vendored

# Set LF as the line ending for JSON and YAML files
*.json text eol=lf
*.yaml text eol=lf
