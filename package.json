{
  "name": "helloblue-ai",
  "version": "1.0.3",
  "description": "A project to facilitate connecting users to company customer services quickly and efficiently.",
  "main": "app.js",
  "scripts": {
    "test": "jest --passWithNoTests",
    "check-updates": "ncu",
    "lint:css": "stylelint '**/*.css'",
    "lint:js": "eslint '**/*.js'",
    "format": "prettier --write '**/*.{html,js,css,json,md}'",
    "build": "pnpm run build:css:prod && copyfiles -u 1 'app/**/*' 'dist/'",
    "build:css:dev": "postcss style.css -o dist/style.min.css",
    "build:css:prod": "postcss style.css -o dist/style.min.css",
    "start": "lite-server --baseDir=.",
    "serve": "serve -s dist",
    "prepare": "[ \"$NODE_ENV\" != \"production\" ] && husky install || echo 'Skipping husky in production'",
    "dev": "concurrently \"pnpm start\" \"pnpm run watch:css\"",
    "watch:css": "postcss style.css -o dist/style.min.css --watch",
    "check-all": "pnpm install && pnpm run lint:js && pnpm run lint:css && pnpm run build && pnpm audit",
    "audit": "pnpm audit",
    "fix": "pnpm audit fix --force",
    "precommit": "lint-staged",
    "clean": "rimraf ./node_modules ./pnpm-lock.yaml ./dist",
    "start:prod": "serve dist"
  },
  "author": "Pejman Haghighatnia",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/HelloblueAI/hbLab-B01.git"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^3.5.0",
    "abort-controller": "^3.0.0",
    "body-parser": "^1.20.3",
    "braces": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-openid-connect": "^2.17.1",
    "fuse.js": "^7.0.0",
    "glob": "^11.0.0",
    "got": "^14.4.5",
    "gotrue-js": "^0.9.29",
    "handlebars": "^4.7.8",
    "husky": "^9.1.7",
    "joi": "^17.13.3",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "lodash.merge": "^4.6.2",
    "micromatch": "^4.0.8",
    "node-fetch": "^2.7.0",
    "path-to-regexp": "^8.2.0",
    "send": "^1.1.0",
    "serve-static": "^1.16.2",
    "set-value": "^4.1.0",
    "shelljs": "^0.8.5",
    "through2": "^4.0.2",
    "yargs-parser": "^21.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "ansi-colors": "^4.1.3",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.1.1",
    "copyfiles": "^2.4.1",
    "cssnano": "^7.0.6",
    "eslint": "^9.17.0",
    "eslint-plugin-prettier": "^5.2.1",
    "fancy-log": "^2.0.0",
    "http-server": "^14.1.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "25.0.1",
    "lint-staged": "^15.2.11",
    "npm-check-updates": "^17.1.12",
    "plugin-error": "^2.0.1",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "serve": "^14.2.4",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "vinyl": "^3.0.0"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,css,html,json,md}": "prettier --write"
  },
  "engines": {
    "node": ">=18.16.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "set-value": "^4.1.0",
      "defaults-deep": "^1.0.0",
      "cookie": "^0.7.0",
      "lodash": "^4.17.21",
      "braces": "^3.0.3",
      "micromatch": "^4.0.8",
      "path-to-regexp": "^8.2.0"
    }
  }
}
