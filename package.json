{
  "name": "helloblue-ai",
  "version": "1.0.1",
  "description": "A project to facilitate connecting users to company customer services quickly and efficiently.",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "check-updates": "ncu",
    "lint:css": "stylelint '**/*.css'",
    "format": "prettier --write '**/*.{html,js,css}'",
    "lint:js": "eslint '**/*.js'",
    "build:css": "postcss style.css -o style.min.css",
    "build": "npm run build:css",
    "start": "npx lite-server --verbose",
    "serve": "serve -s .",
    "prepare": "husky install",
    "dev": "concurrently \"npm run start\" \"npm run watch:css\"",
    "watch:css": "postcss style.css -o style.min.css --watch",
    "check-all": "npm install && npm run lint:js && npm run lint:css && npm run build && npm audit"
  },
  "author": "Pejman Haghighatnia",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/HelloblueAI/hbLab-B01.git"
  },
  "devDependencies": {
    "ansi-colors": "^4.1.3",
    "concurrently": "^9.1.0",
    "cssnano": "^7.0.6",
    "eslint": "^9.16.0",
    "eslint-plugin-prettier": "^5.2.1",
    "fancy-log": "^2.0.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "npm-check-updates": "^17.1.11",
    "plugin-error": "^2.0.1",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.4.1",
    "serve": "^14.2.4",
    "stylelint": "^16.11.0",
    "stylelint-config-standard": "^36.0.1",
    "vinyl": "^3.0.0"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^3.5.0",
    "body-parser": "^1.20.3",
    "braces": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.6",
    "express": "^4.21.1",
    "express-openid-connect": "^2.17.1",
    "fuse.js": "^7.0.0",
    "glob": "^11.0.0",
    "gotrue-js": "^0.9.29",
    "handlebars": "^4.7.8",
    "lodash": "^4.17.21",
    "lodash.merge": "^4.6.2",
    "micromatch": "^4.0.8",
    "path-to-regexp": "^8.2.0",
    "rimraf": "^6.0.1",
    "send": "^1.1.0",
    "serve-static": "^1.16.2",
    "set-value": "^4.1.0",
    "shelljs": "^0.8.5",
    "through2": "^4.0.2",
    "update": "^0.7.4",
    "yargs-parser": "^21.1.1"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,css,html}": "prettier --write"
  },
  "keywords": [
    "customer service",
    "voice AI",
    "company search",
    "automation",
    "web app"
  ],
  "pnpm": {
    "overrides": {
      "set-value": ">=2.0.1",
      "lodash": ">=4.17.21",
      "braces": ">=3.0.3",
      "micromatch": ">=4.0.8",
      "path-to-regexp": ">=3.3.0"
    }
  }
}
