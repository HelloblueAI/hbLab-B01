# Dependency directories
node_modules/
bower_components/

# Build and output directories
build/
dist/ # Exclude dist from tracking (remove if you want to track dist)
out/
.cache/

# Python virtual environments
venv/
new_venv/

# SSL and sensitive files
ssl/
*.crt
*.csr
*.key
*.db
*.db.cache

# Logs and runtime data
logs/
*.log
*.pid
*.pid.lock

# Lock files
pnpm-lock.yaml
package-lock.json
yarn.lock

# Dotenv files (Environment variables)
.env
.env.*

# System-specific files
.DS_Store
Thumbs.db
Icon?

# Editor and IDE settings
.vscode/
.idea/
*.sublime-workspace

# Test and coverage reports
.nyc_output/
coverage/
*.html.report

# Flask instance and cache
instance/
*.pyc
__pycache__/

# Temporary files
*.tmp
*.bak
*.swp
*.temp
.aider*

# Specific directories/files to ignore
_site/
test.txt
test_flask.py

# Netlify configuration and cache
.netlify

# Specific note:
# Remove "!dist/" as Netlify can generate it during deployment.
